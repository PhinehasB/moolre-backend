SPRING_PROFILES_ACTIVE=dev

DB_URL=jdbc:postgresql://host/database?sslmode=require
DB_USERNAME=your_db_user
DB_PASSWORD=your_db_password

JWT_SECRET=replace_with_base64_encoded_512_bit_secret
JWT_ACCESS_TTL=PT15M
JWT_REFRESH_TTL=P30D
JWT_SESSION_TTL=PT12H
JWT_ISSUER=klare-business

REFRESH_TOKEN_PEPPER=replace_with_base64_encoded_256_bit_secret

LOGIN_MAX_FAILED_ATTEMPTS=5
LOGIN_LOCK_DURATION=PT15M
PASSWORD_RESET_TOKEN_TTL=PT30M
EMAIL_VERIFICATION_TOKEN_TTL=P2D
APP_PASSWORD_RESET_URL=http://localhost:3000/reset-password
APP_API_BASE_URL=http://localhost:8080
APP_LOGIN_URL=http://localhost:3000/login

MAIL_HOST=smtp.your-provider.com
MAIL_PORT=587
MAIL_USERNAME=your_smtp_username
MAIL_PASSWORD=your_smtp_password_or_app_password
MAIL_FROM_ADDRESS=no-reply@your-domain.com
MAIL_FROM_NAME=Klare

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

RATE_LIMIT_AUTH_CAPACITY=10
RATE_LIMIT_AUTH_REFILL_TOKENS=10
RATE_LIMIT_AUTH_REFILL_PERIOD=PT1M
RATE_LIMIT_GLOBAL_CAPACITY=120
RATE_LIMIT_GLOBAL_REFILL_TOKENS=120
RATE_LIMIT_GLOBAL_REFILL_PERIOD=PT1M

IDEMPOTENCY_TTL=PT24H

MOOLRE_ENV=sandbox
MOOLRE_CALLBACK_URL=https://your-domain/api/v1/webhooks/moolre

MOOLRE_SANDBOX_BASE_URL=https://sandbox.moolre.com
MOOLRE_SANDBOX_API_USER=your_moolre_username
MOOLRE_SANDBOX_API_KEY=your_sandbox_private_key
MOOLRE_SANDBOX_API_PUBKEY=your_sandbox_public_key
MOOLRE_SANDBOX_ACCOUNT_NUMBER=your_sandbox_account_number
MOOLRE_SANDBOX_CALLBACK_SECRET=your_sandbox_callback_secret

MOOLRE_LIVE_BASE_URL=https://api.moolre.com
MOOLRE_LIVE_API_USER=your_moolre_username
MOOLRE_LIVE_API_KEY=your_live_private_key
MOOLRE_LIVE_API_PUBKEY=your_live_public_key
MOOLRE_LIVE_ACCOUNT_NUMBER=your_live_account_number
MOOLRE_LIVE_CALLBACK_SECRET=your_live_callback_secret
